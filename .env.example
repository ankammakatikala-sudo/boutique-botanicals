# ============================================
# Boutique Botanicals - Environment Variables
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# --- Gemini AI Configuration ---
GEMINI_API_KEY="your_gemini_api_key_here"

# --- Application URL ---
# Set to your Render URL in production (e.g., https://boutique-botanicals.onrender.com)
APP_URL="http://localhost:3000"

# --- Email Configuration (Gmail SMTP) ---
# Used for OTP verification and order receipt emails.
# Requires a Gmail account with 2-Step Verification enabled.
# Generate an App Password at: https://myaccount.google.com/apppasswords
SENDER_EMAIL="your_gmail_address@gmail.com"
APP_PASSWORD="your_gmail_app_password"

# --- Server Configuration ---
# Render uses port 10000 by default. Locally, 3001 is recommended.
SERVER_PORT=3001
